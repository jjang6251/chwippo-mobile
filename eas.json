{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true,
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      // App Review(Guideline 2.1 · 카카오 우회) — 로그인 로고 7연속 탭 숨김 제스처 활성 (빌드 타임 인라인).
      // 숨김 제스처라 상시 ON 이어도 일반 사용자 노출 0 (ADR-052). 실제 스위치는 백엔드
      // REVIEWER_EMAIL·REVIEWER_PASSWORD_HASH — 심사 기간 외엔 env 제거로 404 (제스처 열려도 로그인 불가).
      "env": { "EXPO_PUBLIC_REVIEWER_MODE": "1" },
      "ios": {
        "image": "latest",
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest",
        "resourceClass": "large"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6789707709",
        "appleTeamId": "4Q3P27QUC8"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
