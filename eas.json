{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true,
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "apk",
        "image": "latest"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      // App Review(Guideline 2.1 · 카카오 우회) 제출 빌드에서만 아래 env 주석을 해제하면
      // 로그인 화면 로고 7연속 탭 숨김 제스처가 활성화된다 (EXPO_PUBLIC_REVIEWER_MODE 는 빌드 타임 인라인).
      // 평소 프로덕션 빌드엔 미설정 = 제스처 무반응(일반 사용자 노출 0). 백엔드 REVIEWER_EMAIL·REVIEWER_PASSWORD_HASH 도 함께 설정 필요.
      // "env": { "EXPO_PUBLIC_REVIEWER_MODE": "1" },
      "ios": {
        "image": "latest",
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest",
        "resourceClass": "large"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6789707709",
        "appleTeamId": "4Q3P27QUC8"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
