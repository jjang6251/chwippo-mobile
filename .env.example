# ========================================
# chwippo-mobile 환경 변수 예시
# ========================================
# 실제 값은 .env 에 저장 (git 무시)
# 팀 신규 인원: 이 파일을 .env 로 복사 후 값 채우기

# === Kakao Native SDK ===
# Kakao Developers 콘솔 → 앱 설정 → 앱 키 → 네이티브 앱 키
# 두 개 같은 값으로 채움:
#   - KAKAO_NATIVE_APP_KEY: app.config.ts (build time · Expo config plugin)
#   - EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY: runtime JS (initializeKakaoSDK 호출 용)
KAKAO_NATIVE_APP_KEY=
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=

# === Apple ===
# Apple Developer 포털 → Membership → Team ID
# CEO Organization 등록 완료 후 채움
APPLE_TEAM_ID=

# === Backend API ===
EXPO_PUBLIC_API_URL=https://api.chwippo.com
EXPO_PUBLIC_WEB_URL=https://chwippo.com

# === EAS Build (선택) ===
# EAS 로그인 후 자동 설정. 로컬 build 시만 필요
# EAS_PROJECT_ID=

# === 개발 모드 flag ===
# Reviewer bypass 버튼 노출 여부 (production build 는 false 로 강제됨)
EXPO_PUBLIC_ENABLE_REVIEWER_BYPASS=false
